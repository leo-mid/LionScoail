%h1.mb-4 Posts
.table-responsive
  %table.table.table-striped.table-hover
    %thead.table-dark
      %tr
        %th Id
        %th Post User
        %th Body
        %th Actions

    %tbody
      - @posts.each do |post|
        %tr
          %td= post.id
          %td= post.user.username
          %td= truncate(post.content, length: 50)
          %td= link_to 'Destroy', post, data: { "turbo-method": :delete, turbo_confirm: 'Are you sure?' }, class: "btn btn-sm btn-outline-danger"
%br/
= link_to "Back", admins_index_path, class: "btn btn-secondary"
