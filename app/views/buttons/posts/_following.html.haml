.list-group.flex-row.flex-md-column.mb-3.overflow-auto.flex-nowrap
  = link_to posts_path, class: "list-group-item list-group-item-action flex-fill text-nowrap" do
    .row.g-0.align-items-center
      .col-auto.me-2
        .icon
          = image_tag("icons/icons8/people.png", size: "24x24")
      .col
        Everyones
  = link_to post_following_path, class: "list-group-item list-group-item-action active flex-fill text-nowrap" do
    .row.g-0.align-items-center
      .col-auto.me-2
        .icon
          = image_tag("icons/icons8/home.png", size: "24x24")
      .col
        Following
  = link_to new_post_path, class: "list-group-item list-group-item-action flex-fill text-nowrap" do
    .row.g-0.align-items-center
      .col-auto.me-2
        .icon
          = image_tag("icons/icons8/plus.png", size: "24x24")
      .col
        Create Post