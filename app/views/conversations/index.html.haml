.content-desktop
  .grid-x
    .medium-4.cell
      .callout.convo
        %h4 Messages
        - @conversations.each do |conversation|
          = link_to conversation_messages_path(conversation) do
            .grid-x
              .medium-3.cell
                - if conversation.recipient(current_user).avatar.attached?
                  = image_tag conversation.recipient(current_user).avatar.variant(resize_to_fill: [50, 50])
                - else 
                  = image_tag ("profilepic.png"), :size => "50x20"
              .medium-9.cell
                %h5
                  = conversation.recipient(current_user).username
                  - if !conversation.unread_message_count(current_user).zero?
                    (#{conversation.unread_message_count(current_user)})
                - if conversation.recipient(current_user).updated_at > 5.minutes.ago
                  %h6 Acitve Now
                -else
                  %h6 Active #{time_ago_in_words(conversation.recipient(current_user).updated_at)} ago
    .medium-8.cell
      .callout.msg.blank
        %h4 Start a new coversation
        - @users.each do |user|
          - if (user.following?(current_user) && current_user.following?(user)) && !(Conversation.between(current_user.id,user.id).present?)
            .grid-x 
              .medium-2.cell
                - if user.avatar.attached?
                  = image_tag user.avatar.variant(resize_to_fill: [50, 20])
                - else
                  = image_tag ("profilepic.png"), :size => "50x20"
              .medium-9.cell
                %h4= user.username
                %h5= link_to "Start Conversation", conversations_path(sender_id: current_user.id, receiver_id: user.id),'data-turbo-method': :post

.content-mobile
  %h2 Messages
  - @conversations.each do |conversation|
    = link_to conversation_messages_path(conversation) do
      .callout.convo
        %h4= conversation.recipient(current_user).username
        - if conversation.recipient(current_user).updated_at > 5.minutes.ago
          %h5 Acitve Now
        -else
          %h5 Active #{time_ago_in_words(conversation.recipient(current_user).updated_at)} ago
