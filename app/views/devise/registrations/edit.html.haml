.row.justify-content-center
  .col-12.col-md-10.col-lg-8
    .card.mb-4.shadow-sm.border-primary
      .card-header.bg-primary.text-white
        %h2.h4.mb-0.fw-bold Edit #{resource_name.to_s.humanize}
      .card-body
        = simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f|
          = render "devise/shared/error_messages", resource: resource
          
          %section.mb-4
            %h5.text-primary.border-bottom.pb-2.mb-3 Profile Information
            .row
              .col-md-6
                = f.input :email, autofocus: true, autocomplete: "email"
              .col-md-6
                = f.input :username
            = f.input :body, label: "Bio", input_html: { rows: 3 }
            = f.input :avatar, as: :file, label: "Profile Picture", input_html: { class: 'form-control', accept: 'image/jpeg,image/gif,image/png,image/heic', direct_upload: true }
          
          %section.mb-4
            %h5.text-primary.border-bottom.pb-2.mb-3 Security
            .row
              .col-md-6
                = f.input :password, autocomplete: "new-password", hint: "Leave blank if you don't want to change it", label: "New Password"
              .col-md-6
                = f.input :password_confirmation, autocomplete: "new-password", label: "Confirm New Password"
          
          .alert.alert-info.mb-4
            = f.input :current_password, autocomplete: "current-password", hint: "Enter current password to confirm your changes", required: true

          .d-grid.gap-2.d-md-flex.justify-content-md-end
            = f.submit "Update Profile", class: "btn btn-primary btn-lg px-5"

    .card.border-danger.shadow-sm
      .card-header.bg-danger.text-white
        %h5.mb-0 Danger Zone
      .card-body
        %p.text-muted Notice this will delete all your things across LionNav.com. This action cannot be undone.
        = link_to "Delete Account", registration_path(resource_name), data: { "turbo-method": :delete, turbo_confirm: "Are you absolutely sure? This will delete everything." }, class: "btn btn-outline-danger"
