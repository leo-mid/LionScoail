.row.justify-content-center
  .col-12.col-md-8.col-lg-6
    = simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { data: { turbo: false} } ) do |f|
      .alert.alert-info
        %h1.fw-bold.text-center Log in
        = f.input :email, autofocus: true, autocomplete: "email"
        = f.input :password, autocomplete: "current-password"
        - if devise_mapping.rememberable?
          = f.input :remember_me, as: :boolean
        .actions
          = f.submit "Log in", class: "btn btn-primary"
          = render "devise/shared/links"
