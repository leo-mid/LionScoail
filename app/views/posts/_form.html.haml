= simple_form_for @post do |f|
  = f.error_notification
  = f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present?

  .form-inputs
    = f.input :content, label: "The post", input_html: { rows: 2 }
    = f.input :picture, as: :file, label: "Picture or Video", input_html: { accept: 'image/jpeg,image/gif,image/png,video/mp4,video/mov,video/webm' }

  .form-actions.mt-3
    = f.submit "Post", class: 'btn btn-primary'
