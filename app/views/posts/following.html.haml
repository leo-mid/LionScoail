.row
  .col-md-3
    = render "buttons/posts/following"
  .col-md-9
    .text-center
      %h1 Following Posts
    - @posts.each do |post|
      .card.mb-4.shadow-sm.rounded-3
        .card-body
          .d-flex.align-items-center.mb-3
            - if post.user.avatar.attached?
              = image_tag post.user.avatar.variant(resize_to_fill: [40, 40]), class: "rounded-circle me-2 border border-primary border-2"
            - else
              = image_tag "profilepic.png", size: "40x40", class: "rounded-circle me-2 border border-primary border-2"
            %h6.mb-0= link_to post.user.username, post.user, class: "text-decoration-none fw-bold text-deep-orange"
          
          .mb-3
            - if post.picture.attached?
              - if post.picture.image?
                .thumbnail.text-center= image_tag post.picture.variant(resize_to_limit: [600, 600]), class: "img-fluid rounded"
              - if post.picture.video?
                = video_tag rails_blob_path(post.picture), controls: true, class: "w-100 rounded"

          %p.card-text.fs-5= post.content
          .d-flex.justify-content-between.align-items-center
            %div
              = link_to post, class: "btn btn-sm btn-outline-primary rounded-pill px-3" do
                %i.bi.bi-chat-dots
                Comments
                %span.badge.bg-primary.ms-1= post.comments.count
            %small.text-muted
              = time_ago_in_words(post.created_at)
              ago
          - if current_user?(post.user)
            .mt-3.pt-3.border-top
              = link_to 'Remove Post', post, data: { "turbo-method": :delete, turbo_confirm: 'Are you sure? This cannot be undone.' }, class: "btn btn-sm btn-link text-danger p-0 text-decoration-none"