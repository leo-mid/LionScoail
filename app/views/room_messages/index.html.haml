= turbo_stream_from "room_messages"
.row
  .col-md-4
    .card.mb-4
      .card-body
        %h3 Send a message
        = turbo_frame_tag "new_room_message" do
          = render 'room_messages/form'
        .mt-3
          = link_to "Back", rooms_path, class: "btn btn-secondary"
  .col-md-8
    .card
      .card-header
        %h1.h3.mb-0
          This room is:
          = @room.name
      .card-body.overflow-auto{style: "max-height: 70vh;"}
        = turbo_frame_tag dom_id(@room) do
          = render @room_messages
