= form_for user do |f|
  -if current_user == user
    - if f.object.errors.any?
      #error_explanation
        %h2= "#{pluralize(f.object.errors.count, "error")} prohibited this post from being saved:"
        %ul
          - f.object.errors.full_messages.each do |message|
            %li= message
    .callout
      .field
        = f.label :email
        = f.email_field :email, autofocus: true, autocomplete: "email"
      .field
        = f.label :password
        %i (Leave blank if you don't want to change it)
        = f.password_field :password, autocomplete: "new-password"
      .field
        = f.label :password_confirmation
        = f.password_field :password_confirmation, autocomplete: "new-password"
      .field
        = f.label :Username
        = f.text_field :username
      .field
        = f.label :bio
        = f.text_field :body
      .field
        = f.label :avatar, "Profile Picture"
        = f.file_field :avatar, accept: 'image/jpeg,image/gif,image/png,image/heic', direct_upload: true
      .actions
        = f.submit "Update", class:"button"
      -if current_user == user
        = link_to "Delete Account", user, data: { "turbo-method": :delete, turbo_confirm: "Notice this will delete all your things accross LionNav.com. Do you wish to continue?" }, class: "button"